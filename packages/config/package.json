{
  "name": "@onlyoffice/document-editor-config",
  "version": "1.0.0",
  "description": "ONLYOFFICE Document Editor configuration types and JSON schema",
  "license": "Apache-2.0",
  "author": "ONLYOFFICE",
  "homepage": "https://www.onlyoffice.com/",
  "repository": {
    "type": "git",
    "url": "https://github.com/ONLYOFFICE/web-apps.git",
    "directory": "packages/config"
  },
  "keywords": [
    "onlyoffice",
    "document-editor",
    "config",
    "configuration",
    "schema",
    "json-schema",
    "typescript"
